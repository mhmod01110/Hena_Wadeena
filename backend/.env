# Backend Environment Variables
# Local defaults aligned with docker-compose

# Shared
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=hena-wadeena-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
DEBUG=true

# Service URLs (used by gateway and cross-service calls)
AUTH_SERVICE_URL=http://localhost:8001
USER_SERVICE_URL=http://localhost:8002
MAP_SERVICE_URL=http://localhost:8003
MARKET_SERVICE_URL=http://localhost:8004
GUIDE_SERVICE_URL=http://localhost:8005
INVESTMENT_SERVICE_URL=http://localhost:8006
PAYMENT_SERVICE_URL=http://localhost:8007
NOTIFICATION_SERVICE_URL=http://localhost:8008
SEARCH_SERVICE_URL=http://localhost:8009
AI_SERVICE_URL=http://localhost:8010
ADMIN_SERVICE_URL=http://localhost:8011
ANALYTICS_SERVICE_URL=http://localhost:8012
MEDIA_SERVICE_URL=http://localhost:8013

